# Airflux Agent Platform — Environment Variables
# Copy this file to .env.local and fill in the values.

# ─── LLM Provider ──────────────────────────────────────────────
# Option 1: Anthropic API key (direct)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Option 2: Claude Code credentials (auto-detected from ~/.claude/.credentials.json)
# No config needed — just run `claude login`

# ─── Server ────────────────────────────────────────────────────
PORT=3000

# ─── Admin Auth (production only) ──────────────────────────────
# ADMIN_API_KEY=your-secret-admin-key

# ─── CORS (production only) ────────────────────────────────────
# CORS_ORIGIN=https://your-dashboard.example.com

# ─── Slack Integration (optional) ──────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...

# ─── Database ──────────────────────────────────────────────────
# LOG_DB_PATH=./data/airflux.db  (default: ../../data/airflux.db)
