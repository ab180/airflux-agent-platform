# Airflux Agent Platform — Environment Variables
# Copy this file to .env.local and fill in the values.

# ─── LLM Provider ──────────────────────────────────────────────
# Option 1: Anthropic API key (direct)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Option 2: Claude Code SSO (auto-detected)
# No config needed — just run `claude login`

# Option 3: OpenAI API key (for Codex CLI users)
# OPENAI_API_KEY=sk-...

# ─── Server ────────────────────────────────────────────────────
PORT=3000

# ─── Admin Auth (production only) ──────────────────────────────
# ADMIN_API_KEY=your-secret-admin-key

# ─── CORS (production only) ────────────────────────────────────
# CORS_ORIGIN=https://your-dashboard.example.com

# ─── Slack Integration (optional) ──────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...

# ─── Auth Mode ─────────────────────────────────────────────────
# "local" (default): no auth, all access allowed
# "google-sso": Google OAuth with workspace domain restriction
# NEXT_PUBLIC_AUTH_MODE=local

# ─── Google SSO (NEXT_PUBLIC_AUTH_MODE=google-sso일 때만 필요) ──
# NEXTAUTH_URL=http://localhost:3001
# NEXTAUTH_SECRET=your-random-secret-here
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# GOOGLE_WORKSPACE_DOMAIN=ab180.co
# ADMIN_EMAILS=admin@ab180.co

# ─── Database ──────────────────────────────────────────────────
# LOG_DB_PATH=./data/airflux.db  (default: ../../data/airflux.db)
